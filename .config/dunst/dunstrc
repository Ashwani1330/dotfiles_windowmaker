[global]
    font = Monospace 10
    frame_width = 2

    # Muted mid-tone purple from the alleyway walls
    frame_color = "#4d3d60"

    # Deep shadow purple/black for the background
    background = "#131018"

    # Washed-out, pale text to match the sky
    foreground = "#e5e1eb"

    # Lighter, desaturated purple for the actual volume/brightness bar
    highlight = "#8772a8"

    timeout = 5
